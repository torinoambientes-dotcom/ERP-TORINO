{
  "entities": {
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Represents a project with a client and multiple environments.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project." },
        "clientName": { "type": "string", "description": "The name of the client." },
        "environments": {
          "type": "array",
          "items": { "$ref": "#/entities/Environment" }
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the project was completed."
        }
      },
      "required": ["id", "clientName", "environments"]
    },
    "Environment": {
      "title": "Environment",
      "type": "object",
      "description": "An environment within a project, containing multiple pieces of furniture.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the environment." },
        "name": { "type": "string", "description": "The name of the environment (e.g., 'Kitchen')." },
        "furniture": {
          "type": "array",
          "items": { "$ref": "#/entities/Furniture" }
        }
      },
      "required": ["id", "name", "furniture"]
    },
    "Furniture": {
      "title": "Furniture",
      "type": "object",
      "description": "A single piece of furniture with its production stages.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the furniture." },
        "name": { "type": "string", "description": "The name of the furniture (e.g., 'Top Cabinet')." },
        "measurement": { "$ref": "#/entities/ProductionStage" },
        "cutting": { "$ref": "#/entities/ProductionStage" },
        "purchase": { "$ref": "#/entities/ProductionStage" },
        "assembly": { "$ref": "#/entities/ProductionStage" },
        "comments": {
          "type": "array",
          "items": { "$ref": "#/entities/Comment" }
        },
        "pendencies": {
          "type": "array",
          "items": { "$ref": "#/entities/Pendency" }
        },
        "materials": {
          "type": "array",
          "items": { "$ref": "#/entities/MaterialItem" }
        },
        "glassItems": {
          "type": "array",
          "items": { "$ref": "#/entities/GlassItem" }
        },
        "profileDoors": {
          "type": "array",
          "items": { "$ref": "#/entities/ProfileDoorItem" }
        }
      },
      "required": ["id", "name", "measurement", "cutting", "purchase", "assembly"]
    },
    "ProductionStage": {
      "title": "Production Stage",
      "type": "object",
      "description": "Represents a single stage of production for a piece of furniture.",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["todo", "in_progress", "done"]
        },
        "responsibleId": {
          "type": "string",
          "description": "The ID of the team member responsible for this stage."
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the stage started."
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the stage was completed."
        }
      },
      "required": ["status"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "A comment made by a team member on a piece of furniture.",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string", "description": "ID of the team member who made the comment." },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "memberId", "text", "timestamp"]
    },
    "Pendency": {
      "title": "Pendency",
      "type": "object",
      "description": "A task or issue that needs to be resolved for a piece of furniture.",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "isResolved": { "type": "boolean" },
        "authorId": { "type": "string", "description": "ID of the team member who created the pendency." }
      },
      "required": ["id", "text", "isResolved", "authorId"]
    },
    "MaterialItem": {
      "title": "MaterialItem",
      "type": "object",
      "description": "Represents a single material item required for a piece of furniture.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "unit"]
    },
    "GlassItem": {
      "title": "GlassItem",
      "type": "object",
      "description": "Represents a single glass item required for a piece of furniture.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Vidro Incolor", "Espelho", "Vidro Reflecta Incolor", "Vidro Reflecta Bronze", "Vidro Reflecta Fume", "Espelho Fumê", "Espelho Bronze"]},
        "height": { "type": "number" },
        "width": { "type": "number" },
        "quantity": { "type": "number" },
        "isBeveled": { "type": "boolean", "description": "Indicates if the glass has a beveled edge." }
      },
      "required": ["id", "type", "height", "width", "quantity"]
    },
    "ProfileDoorItem": {
      "title": "ProfileDoorItem",
      "type": "object",
      "description": "Represents a single profile door required for a piece of furniture.",
      "properties": {
        "id": { "type": "string" },
        "profileColor": { "type": "string", "enum": ["Preto", "Aluminio", "Inox"]},
        "glassType": { "type": "string", "enum": ["Incolor", "Fume", "Bronze", "Espelho Fume", "Espelho Bronze", "Espelho Prata", "Reflecta Incolor", "Reflecta Fume", "Reflecta Prata"]},
        "handleType": { "type": "string", "enum": ["Linear inteiro", "Aba Usinada", "Sem Puxador"]},
        "height": { "type": "number" },
        "width": { "type": "number" },
        "quantity": { "type": "number" }
      },
      "required": ["id", "profileColor", "glassType", "handleType", "height", "width", "quantity"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "type": "object",
      "description": "Represents a team member.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The user ID from Firebase Authentication." },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "color": { "type": "string", "description": "A hex color code for the member's label." },
        "role": { "type": "string", "description": "The role of the team member (e.g., 'Marceneiro', 'Projetista')." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "URL of the team member's avatar image." }
      },
      "required": ["id", "userId", "name", "email", "color", "role"]
    },
    "StockItem": {
      "title": "StockItem",
      "type": "object",
      "description": "Represents an item in the inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number", "description": "The minimum stock quantity to trigger an alert." },
        "category": { "type": "string", "description": "The category of the stock item." },
        "alertHandledAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp for when a low stock alert was handled."
        }
      },
      "required": ["id", "name", "quantity", "unit", "category"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "type": "object",
      "description": "Represents a single movement (entry or exit) of a stock item.",
      "properties": {
        "id": { "type": "string" },
        "stockItemId": { "type": "string", "description": "The ID of the stock item this movement belongs to." },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "quantity": { "type": "number" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "memberId": { "type": "string" }
      },
      "required": ["id", "stockItemId", "type", "quantity", "timestamp", "memberId"]
    },
    "StockCategory": {
      "title": "StockCategory",
      "type": "object",
      "description": "Represents a category for stock items.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores all project data."
    },
    "/team_members/{teamMemberId}": {
      "schema": { "$ref": "#/entities/TeamMember" },
      "description": "Stores information about team members."
    },
    "/stock_items/{stockItemId}": {
      "schema": { "$ref": "#/entities/StockItem" },
      "description": "Stores inventory items."
    },
    "/stock_movements/{movementId}": {
      "schema": { "$ref": "#/entities/StockMovement" },
      "description": "Stores the movement history for all stock items."
    },
    "/stock_categories/{stockCategoryId}": {
      "schema": { "$ref": "#/entities/StockCategory" },
      "description": "Stores the available categories for stock items."
    }
  }
}
