/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for team members
 * and allows public read access to projects while restricting writes to authenticated users.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project data, publicly readable, but owner-restricted writes.
 * - /team_members/{teamMemberId}: Stores team member data, with owner-only access.
 *
 * Key Security Decisions:
 * - Public read access is granted to the /projects collection to facilitate open access to project information.
 * - All write operations are strictly controlled via authentication and ownership checks.
 * - Listing of team members is restricted to authenticated users only.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to projects and restricts write access to authenticated users.
     * @path /projects/{projectId}
     * @allow (get, list): Any user can read project data.
     * @allow (create): An authenticated user can create a project. The 'id' field must match the 'projectId'.
     * @allow (update, delete): Only the user who created the project can update or delete it.
     * @deny create: if request.auth == null; // Denies unauthenticated creation
     * @deny update: if request.auth == null; // Denies unauthenticated updates
     * @deny delete: if request.auth == null; // Denies unauthenticated deletes
     * @principle Allows public read access while enforcing owner-only writes for projects.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Restricts access to team member data to the owner only.
     * @path /team_members/{teamMemberId}
     * @allow (get, list): Only the team member can read their own data.
     * @allow (create): A team member can create their own record if the 'id' matches their 'teamMemberId'.
     * @allow (update, delete): Only the team member can update or delete their own data.
     * @deny create: if request.auth == null; // Denies unauthenticated creation
     * @deny update: if request.auth == null; // Denies unauthenticated updates
     * @deny delete: if request.auth == null; // Denies unauthenticated deletes
     * @principle Enforces document ownership for team member data.
     */
    match /team_members/{teamMemberId} {
      allow get: if isOwner(teamMemberId);
      allow list: if isSignedIn();
      allow create: if isOwner(teamMemberId);
      allow update: if isExistingOwner(teamMemberId);
      allow delete: if isExistingOwner(teamMemberId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}