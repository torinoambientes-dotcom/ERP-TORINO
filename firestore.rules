/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes strong authorization based on user identity.
 * Read access is generally open unless specifically restricted.
 * Write access is strictly controlled, typically requiring user authentication.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project information.
 * - /team_members/{teamMemberId}: Stores team member profiles.
 * - /appointments/{appointmentId}: Stores appointment and task data.
 * - /stock_items/{stockItemId}: Stores stock inventory items.
 * - /stock_movements/{movementId}: Tracks stock movement history.
 * - /stock_categories/{stockCategoryId}: Stores categories for stock items.
 * - /purchase_requests/{purchaseRequestId}: Stores ad-hoc purchase requests.
 *
 * Key Security Decisions:
 * - Listing of purchase requests is open to all authenticated users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /projects collection.
     * @path /projects/{projectId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create projects.
     * @allow (update, delete): Only the project owner can update or delete projects.
     * @deny (create): if the project's ownerId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the project.
     * @principle Public read, owner-only writes, enforcing authentication for project creation.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /team_members collection.
     * @path /team_members/{teamMemberId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create team members.
     * @allow (update, delete): Only the team member owner can update or delete their profile.
     * @deny (create): if the team member's userId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the team member profile.
     * @principle Public read, owner-only writes, enforcing authentication for team member creation.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(teamMemberId);
    }

    /**
     * @description Rules for the /appointments collection.
     * @path /appointments/{appointmentId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create appointments.
     * @allow (update, delete): Only the appointment owner can update or delete appointments.
     * @deny (create): if the appointment's creatorId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the appointment.
     * @principle Public read, owner-only writes, enforcing authentication for appointment creation.
     */
    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /stock_items collection.
     * @path /stock_items/{stockItemId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create stock items.
     * @allow (update, delete): Only the stock item owner can update or delete stock items.
     * @deny (create): if the stock item's creatorId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the stock item.
     * @principle Public read, owner-only writes, enforcing authentication for stock item creation.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /stock_movements collection.
     * @path /stock_movements/{movementId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create stock movements.
     * @allow (update, delete): Only the stock movement owner can update or delete stock movements.
     * @deny (create): if the stock movement's creatorId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the stock movement.
     * @principle Public read, owner-only writes, enforcing authentication for stock movement creation.
     */
    match /stock_movements/{movementId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /stock_categories collection.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create stock categories.
     * @allow (update, delete): Only the stock category owner can update or delete stock categories.
     * @deny (create): if the stock category's creatorId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the stock category.
     * @principle Public read, owner-only writes, enforcing authentication for stock category creation.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /purchase_requests collection.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (get, list): Allow any signed-in user to read any purchase request.
     * @allow (create): Only authenticated users can create purchase requests.
     * @allow (update, delete): Only the purchase request owner can update or delete their requests.
     * @deny (create): if the purchase request's requesterId doesn't match the request's auth UID.
     * @deny (update, delete): if the user is not the owner of the purchase request.
     * @principle Open read for authenticated users, owner-only writes, enforcing authentication for creation.
     */
    match /purchase_requests/{purchaseRequestId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.requesterId);
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }
}