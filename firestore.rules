rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Requires authentication for all access.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces user-based ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user ID matches the resource owner ID, and that the resource exists.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces user-based ownership and resource existence.
     */
    function isExistingOwner(ownerId) {
        return isSignedIn() && isOwner(ownerId) && resource != null;
    }

    match /{path=**} {
        allow read, write: if false;
    }

    /**
     * @description Defines rules for the /post_it_notes collection.
     * @path /post_it_notes/{documentId}
     * @allow Signed-in user can list
     * @deny Non-signed-in user cannot list
     * @principle Requires authentication for all access.
     */
    match /post_it_notes/{documentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Defines rules for the /projects collection.
     * @path /projects/{projectId}
     * @allow Signed-in user can read
     * @deny Non-signed-in user cannot read
     * @principle Requires authentication for all access.
     */
    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Defines rules for the /team_members collection.
     * @path /team_members/{teamMemberId}
     * @allow Signed-in user can read
     * @deny Non-signed-in user cannot read
     * @principle Requires authentication for all access.
     */
    match /team_members/{teamMemberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Defines rules for the /appointments collection.
     * @path /appointments/{appointmentId}
     * @allow Signed-in user can read
     * @deny Non-signed-in user cannot read
     * @principle Requires authentication for all access.
     */
    match /appointments/{appointmentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
