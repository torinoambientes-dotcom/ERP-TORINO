/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model for all data.
 * Team members can read and write their own documents and can create, update, and delete stock movement documents.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project data. Access is unrestricted.
 * - /team_members/{teamMemberId}: Stores team member data. Team members can read and write their own documents.
 * - /appointments/{appointmentId}: Stores appointment data. Access is unrestricted.
 * - /stock_items/{stockItemId}: Stores inventory items. Access is unrestricted.
 * - /stock_movements/{movementId}: Stores the movement history for all stock items. Team members can create, update, and delete stock movement documents.
 * - /stock_categories/{stockCategoryId}: Stores the available categories for stock items. Access is unrestricted.
 *
 * Key Security Decisions:
 * - Unrestricted access to projects, appointments, stock items and stock categories.
 * - Team members have owner access to their own documents.
 * - Team members can create, update, and delete stock movement documents, as requested in user prompt.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read project data.
     * @path /projects/{projectId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Public read access for project data.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows team members to read and write their own team member document.
     * @path /team_members/{teamMemberId}
     * @allow (get, list, create, update, delete) User with matching ID can read/write
     * @deny (get, list, create, update, delete) User without matching ID cannot read/write
     * @principle Enforces document ownership for team member data.
     */
    match /team_members/{teamMemberId} {
      allow get: if isSignedIn() && isOwner(teamMemberId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(teamMemberId);
      allow update: if isSignedIn() && isExistingOwner(teamMemberId);
      allow delete: if isSignedIn() && isExistingOwner(teamMemberId);
    }

    /**
     * @description Allows anyone to read appointment data.
     * @path /appointments/{appointmentId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Public read access for appointment data.
     */
    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows anyone to read stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Public read access for stock item data.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows all team members to create, update, and delete stock movement data.
     * @path /stock_movements/{movementId}
     * @allow (get, list, create, update, delete)
     * @deny (none)
     * @principle Enforces document ownership for team member data.
     */
    match /stock_movements/{movementId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows anyone to read stock category data.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Public read access for stock category data.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}