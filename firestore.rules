/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a data-centric security model. Access is generally open for reads,
 * but strictly controlled for writes, requiring authentication and authorization.
 *
 * Data Structure:
 * The Firestore database contains top-level collections for projects, team members, appointments,
 * stock items, stock movements, stock categories, purchase requests, and quotes.
 * Each document in these collections is identified by a unique ID.
 *
 * Key Security Decisions:
 * - Public Read Access: Read access is generally open to all users.
 * - Authenticated Writes: Write access is restricted to authenticated users.
 * - No User Listing: Listing all users is not permitted.
 * - Flexible Data Shapes: Data validation is minimized to allow for rapid prototyping.
 *
 * Denormalization for Authorization:
 * Not applicable in this case, as the data model does not require complex authorization checks
 * beyond verifying the user's authentication status.
 *
 * Structural Segregation:
 * Not applicable in this case, as there is no need to segregate private and public data within collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read access to all projects. Writes are only allowed for authenticated users.
     * @path /projects/{projectId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read project data but only signed in users can create, update, or delete it.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all team members. Writes are only allowed for authenticated users.
     * @path /team_members/{teamMemberId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read team member data but only signed in users can create, update, or delete it.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all appointments. Writes are only allowed for authenticated users.
     * @path /appointments/{appointmentId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read appointment data but only signed in users can create, update, or delete it.
     */
    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all stock items. Writes are only allowed for authenticated users.
     * @path /stock_items/{stockItemId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read stock item data but only signed in users can create, update, or delete it.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all stock movements. Writes are only allowed for authenticated users.
     * @path /stock_movements/{movementId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read stock movement data but only signed in users can create, update, or delete it.
     */
    match /stock_movements/{movementId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all stock categories. Writes are only allowed for authenticated users.
     * @path /stock_categories/{stockCategoryId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read stock category data but only signed in users can create, update, or delete it.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all purchase requests. Writes are only allowed for authenticated users.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read purchase request data but only signed in users can create, update, or delete it.
     */
    match /purchase_requests/{purchaseRequestId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read access to all quotes. Writes are only allowed for authenticated users.
     * @path /quotes/{quoteId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Allows any user to read quote data but only signed in users can create, update, or delete it.
     */
    match /quotes/{quoteId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}