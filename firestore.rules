/**
 * @fileOverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset is in prototyping mode and prioritizes strict authorization over data validation.
 * It enforces ownership where possible, but trusts the client to provide valid data.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project data.
 * - /team_members/{teamMemberId}: Stores team member data.
 *
 * Key Security Decisions:
 * - All write operations require authentication.
 * - List operations are generally disallowed except where explicitly permitted.
 * - Data validation is minimal, focusing on authorization-critical fields.
 *
 * Denormalization for Authorization:
 * The system currently assumes no denormalization is required. If more complex
 * authorization schemes are needed, consider denormalizing data (e.g., copying
 * user roles onto project documents) to avoid costly `get()` calls in the rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to project documents.
     * @path /projects/{projectId}
     * @allow (create) Signed-in user can create a project.
     * @deny (create) Anonymous user cannot create a project.
     * @allow (get, list) Anyone can read project data.
     * @allow (update, delete) No one can update or delete project data in this prototype.
     * @principle Allows public read access but restricts modifications.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Controls access to team member documents.
     * @path /team_members/{teamMemberId}
     * @allow (create) Signed-in user can create a team member document if the ID matches their UID.
     * @deny (create) Signed-in user cannot create a team member document if the ID does not match their UID.
     * @allow (get) Anyone can read team member data.
     * @allow (list) Anyone can list team member data.
     * @allow (update, delete) No one can update or delete team member data.
     * @principle Enforces ownership for creation; allows public read-only access.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == teamMemberId;
      allow update, delete: if false;
    }

    // ---- Helper functions ----
    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}