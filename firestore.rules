/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model, where team members have different levels of access
 * to different parts of the application.  All documents are secured to prevent unauthorized access.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project data, no role-based access is specified.
 * - /team_members/{teamMemberId}: Stores team member information, accessible to authenticated users.
 * - /stock_items/{stockItemId}: Stores inventory items, accessible to authenticated users.
 * - /stock_movements/{movementId}: Stores stock movement history, accessible to authenticated users.
 * - /stock_categories/{stockCategoryId}: Stores stock categories, accessible to authenticated users.
 *
 * Key Security Decisions:
 * - Listing of `team_members` is only allowed to authenticated users.
 * - No validation of data shapes in this prototype.
 * - All write operations require authentication.
 *
 * Denormalization for Authorization:
 *   - The responsibleId field in the ProductionStage entity will be used to check if the current user is the responsible for that stage.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to project documents.
     * @path /projects/{projectId}
     * @allow (get, list): Any authenticated user can read project data.
     * @allow (create, update, delete): Only authenticated users can modify project data.
     * @deny  (create): if request.auth == null;
     * @deny (update): if request.auth == null || resource == null;
     * @deny (delete): if request.auth == null || resource == null;
     * @principle Requires user authentication for all write operations.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows access to team member documents.
     * @path /team_members/{teamMemberId}
     * @allow (get): Any authenticated user can read team member data.
     * @allow (list): Any authenticated user can list team members.
     * @allow (create, update, delete): Only authenticated users can create, update, and delete team member data.
     * @deny  (create): if request.auth == null;
     * @deny (update): if request.auth == null || resource == null;
     * @deny (delete): if request.auth == null || resource == null;
     * @principle Requires user authentication for all write operations.
     */
    match /team_members/{teamMemberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows access to stock item documents.
     * @path /stock_items/{stockItemId}
     * @allow (get, list): Any authenticated user can read stock item data.
     * @allow (create, update, delete): Only authenticated users can modify stock item data.
     * @deny  (create): if request.auth == null;
     * @deny (update): if request.auth == null || resource == null;
     * @deny (delete): if request.auth == null || resource == null;
     * @principle Requires user authentication for all write operations.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows access to stock movement documents.
     * @path /stock_movements/{movementId}
     * @allow (get, list): Any authenticated user can read stock movement data.
     * @allow (create, update, delete): Only authenticated users can modify stock movement data.
     * @deny  (create): if request.auth == null;
     * @deny (update): if request.auth == null || resource == null;
     * @deny (delete): if request.auth == null || resource == null;
     * @principle Requires user authentication for all write operations.
     */
    match /stock_movements/{movementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows access to stock category documents.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list): Any authenticated user can read stock category data.
     * @allow (create, update, delete): Only authenticated users can modify stock category data.
     * @deny  (create): if request.auth == null;
     * @deny (update): if request.auth == null || resource == null;
     * @deny (delete): if request.auth == null || resource == null;
     * @principle Requires user authentication for all write operations.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}