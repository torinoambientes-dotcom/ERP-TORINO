/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict owner-only access model for most collections.
 * Only authenticated users can access the data, and they can only access data
 * that they own (i.e., their user ID matches an `authorId` or `memberId` field).
 *
 * Data Structure:
 * - `/projects/{projectId}`: Stores project data. Access is restricted to the owner (creator) of the project.
 * - `/team_members/{teamMemberId}`: Stores team member data. Access is restricted to the owner (creator) of the team member.
 * - `/appointments/{appointmentId}`: Stores appointment data. Access is restricted to the owner (creator) of the appointment.
 * - `/stock_items/{stockItemId}`: Stores stock item data. Access is restricted to the owner (creator) of the stock item.
 * - `/stock_movements/{movementId}`: Stores stock movement data. Access is restricted to the owner (creator) of the stock movement.
 * - `/stock_categories/{stockCategoryId}`: Stores stock category data. Access is restricted to the owner (creator) of the stock category.
 * - `/purchase_requests/{purchaseRequestId}`: Stores purchase request data. Access is restricted to the owner (creator) of the purchase request.
 * - `/quotes/{quoteId}`: Stores quote data. Access is restricted to the owner (creator) of the quote.
 * - `/quote_materials/{quoteMaterialId}`: Stores quote material data. Access is restricted to the owner (creator) of the quote material.
 * - `/quote_material_categories/{quoteMaterialCategoryId}`: Stores quote material category data. Access is restricted to the owner (creator) of the quote material category.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy and prevent enumeration attacks.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 * - Write operations are NEVER allowed with `if true;` to prevent unauthorized data modification.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces project-level access control. Only the project owner can read, create, update, or delete project data.
     * @path /projects/{projectId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Enforces team member-level access control. Only the team member owner can read, create, update, or delete team member data.
     * @path /team_members/{teamMemberId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Enforces appointment-level access control. Only the appointment owner can read, create, update, or delete appointment data.
     * @path /appointments/{appointmentId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Enforces stock item-level access control. Only the stock item owner can read, create, update, or delete stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Enforces stock movement-level access control. Only the stock movement owner can read, create, update, or delete stock movement data.
     * @path /stock_movements/{movementId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /stock_movements/{movementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Enforces stock category-level access control. Only the stock category owner can read, create, update, or delete stock category data.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list) if isSignedIn();
     * @allow (create) if isSignedIn();
     * @allow (update, delete) if isSignedIn();
     * @deny (create) if !isSignedIn();
     * @deny (update, delete) if !isSignedIn();
     * @principle Enforces document ownership for writes.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

        /**
         * @description Enforces purchase request-level access control. Only the purchase request owner can read, create, update, or delete purchase request data.
         * @path /purchase_requests/{purchaseRequestId}
         * @allow (get, list) if isSignedIn();
         * @allow (create) if isSignedIn();
         * @allow (update, delete) if isSignedIn();
         * @deny (create) if !isSignedIn();
         * @deny (update, delete) if !isSignedIn();
         * @principle Enforces document ownership for writes.
         */
        match /purchase_requests/{purchaseRequestId} {
            allow get, list: if isSignedIn();
            allow create: if isSignedIn();
            allow update, delete: if isSignedIn() && resource != null;
        }

        /**
         * @description Enforces quote-level access control. Only the quote owner can read, create, update, or delete quote data.
         * @path /quotes/{quoteId}
         * @allow (get, list) if isSignedIn();
         * @allow (create) if isSignedIn();
         * @allow (update, delete) if isSignedIn();
         * @deny (create) if !isSignedIn();
         * @deny (update, delete) if !isSignedIn();
         * @principle Enforces document ownership for writes.
         */
        match /quotes/{quoteId} {
            allow get, list: if isSignedIn();
            allow create: if isSignedIn();
            allow update, delete: if isSignedIn() && resource != null;
        }

        /**
         * @description Enforces quote material-level access control. Only the quote material owner can read, create, update, or delete quote material data.
         * @path /quote_materials/{quoteMaterialId}
         * @allow (get, list) if isSignedIn();
         * @allow (create) if isSignedIn();
         * @allow (update, delete) if isSignedIn();
         * @deny (create) if !isSignedIn();
         * @deny (update, delete) if !isSignedIn();
         * @principle Enforces document ownership for writes.
         */
        match /quote_materials/{quoteMaterialId} {
            allow get, list: if isSignedIn();
            allow create: if isSignedIn();
            allow update, delete: if isSignedIn() && resource != null;
        }

        /**
         * @description Enforces quote material category-level access control. Only the quote material category owner can read, create, update, or delete quote material category data.
         * @path /quote_material_categories/{quoteMaterialCategoryId}
         * @allow (get, list) if isSignedIn();
         * @allow (create) if isSignedIn();
         * @allow (update, delete) if isSignedIn();
         * @deny (create) if !isSignedIn();
         * @deny (update, delete) if !isSignedIn();
         * @principle Enforces document ownership for writes.
         */
        match /quote_material_categories/{quoteMaterialCategoryId} {
            allow get, list: if isSignedIn();
            allow create: if isSignedIn();
            allow update, delete: if isSignedIn() && resource != null;
        }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}