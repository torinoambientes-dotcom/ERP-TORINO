/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a basic authorization model where most top-level collections are accessible to any logged-in user.
 * More restrictive access control (e.g., ownership) will be applied where necessary.
 * Data validation is relaxed during this prototyping phase to facilitate rapid iteration,
 * focusing on authorization and relational integrity checks.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections, including:
 * - /projects/{projectId}: Stores project data.
 * - /team_members/{teamMemberId}: Stores team member information.
 * - /appointments/{appointmentId}: Stores calendar appointments.
 * - /tasks/{taskId}: Stores generic tasks.
 * - /stock_items/{stockItemId}: Stores inventory items.
 * - /stock_movements/{movementId}: Stores stock movement history.
 * - /stock_categories/{stockCategoryId}: Stores stock item categories.
 * - /purchase_requests/{purchaseRequestId}: Stores purchase requests.
 * - /quotes/{quoteId}: Stores quotes.
 * - /quote_materials/{quoteMaterialId}: Stores quote materials.
 * - /quote_material_categories/{quoteMaterialCategoryId}: Stores quote material categories.
 *
 * Key Security Decisions:
 * - All logged-in users can read (get, list) most top-level collections.
 * - Write access (create, update, delete) to most collections is restricted to logged-in users.
 * - No strict data validation is enforced during prototyping, except for authorization and relational integrity.
 * - The ruleset prioritizes simplicity and flexibility for rapid development.
 * - Public listing (`allow list: if true;`) is used with caution and only when all documents in a collection are intended to be public.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read and write projects.
     * @path /projects/{projectId}
     * @allow (read) Authenticated user can read any project.
     * @allow (create) Authenticated user can create a project.
     * @deny (update) Non-authenticated user cannot update a project.
     * @deny (delete) Non-authenticated user cannot delete a project.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write team members.
     * @path /team_members/{teamMemberId}
     * @allow (read) Authenticated user can read any team member.
     * @allow (create) Authenticated user can create a team member.
     * @deny (update) Non-authenticated user cannot update a team member.
     * @deny (delete) Non-authenticated user cannot delete a team member.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write appointments.
     * @path /appointments/{appointmentId}
     * @allow (read) Authenticated user can read any appointment.
     * @allow (create) Authenticated user can create an appointment.
     * @deny (update) Non-authenticated user cannot update an appointment.
     * @deny (delete) Non-authenticated user cannot delete an appointment.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write tasks.
     * @path /tasks/{taskId}
     * @allow (read) Authenticated user can read any task.
     * @allow (create) Authenticated user can create a task.
     * @deny (update) Non-authenticated user cannot update a task.
     * @deny (delete) Non-authenticated user cannot delete a task.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write stock items.
     * @path /stock_items/{stockItemId}
     * @allow (read) Authenticated user can read any stock item.
     * @allow (create) Authenticated user can create a stock item.
     * @deny (update) Non-authenticated user cannot update a stock item.
     * @deny (delete) Non-authenticated user cannot delete a stock item.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write stock movements.
     * @path /stock_movements/{movementId}
     * @allow (read) Authenticated user can read any stock movement.
     * @allow (create) Authenticated user can create a stock movement.
     * @deny (update) Non-authenticated user cannot update a stock movement.
     * @deny (delete) Non-authenticated user cannot delete a stock movement.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /stock_movements/{movementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write stock categories.
     * @path /stock_categories/{stockCategoryId}
     * @allow (read) Authenticated user can read any stock category.
     * @allow (create) Authenticated user can create a stock category.
     * @deny (update) Non-authenticated user cannot update a stock category.
     * @deny (delete) Non-authenticated user cannot delete a stock category.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write purchase requests.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (read) Authenticated user can read any purchase request.
     * @allow (create) Authenticated user can create a purchase request.
     * @deny (update) Non-authenticated user cannot update a purchase request.
     * @deny (delete) Non-authenticated user cannot delete a purchase request.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /purchase_requests/{purchaseRequestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write quotes.
     * @path /quotes/{quoteId}
     * @allow (read) Authenticated user can read any quote.
     * @allow (create) Authenticated user can create a quote.
     * @deny (update) Non-authenticated user cannot update a quote.
     * @deny (delete) Non-authenticated user cannot delete a quote.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /quotes/{quoteId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

   /**
     * @description Allows any authenticated user to read and write quote materials.
     * @path /quote_materials/{quoteMaterialId}
     * @allow (read) Authenticated user can read any quote material.
     * @allow (create) Authenticated user can create a quote material.
     * @deny (update) Non-authenticated user cannot update a quote material.
     * @deny (delete) Non-authenticated user cannot delete a quote material.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /quote_materials/{quoteMaterialId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write quote material categories.
     * @path /quote_material_categories/{quoteMaterialCategoryId}
     * @allow (read) Authenticated user can read any quote material category.
     * @allow (create) Authenticated user can create a quote material category.
     * @deny (update) Non-authenticated user cannot update a quote material category.
     * @deny (delete) Non-authenticated user cannot delete a quote material category.
     * @principle Allows any authenticated user to perform CRUD operations.
     */
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}