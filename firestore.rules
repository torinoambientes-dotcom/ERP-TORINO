/**
 * @fileoverview Firestore Security Rules for Production Prototyping
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid prototyping by focusing on authorization and relationship enforcement,
 * while minimizing data-shape validation.  It enforces strict ownership and role-based access where applicable.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project details.
 * - /team_members/{teamMemberId}: Stores team member profiles.
 * - /stock_items/{stockItemId}: Stores stock items.
 * - /stock_items/{stockItemId}/movements/{movementId}: Tracks stock movements.
 *
 * Key Security Decisions:
 * - Team members are publicly listable but only modifiable by themselves.
 * - Stock items are publicly readable, but only team members can create, update, and delete them.
 * - Stock movements are nested under stock items, readable by anyone, but only team members can create them.
 *
 * Denormalization for Authorization:
 *  - The project documents do not store team member ids, therefore team members cannot be assigned directly to a project.
 *  - Stock movements keep the `memberId` for auditing.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read project details, but restricts writes to team members.
     * @path /projects/{projectId}
     * @allow get, list: if true;
     * @allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @principle Public read, owner-only writes (requires 'ownerId' field in document).
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows anyone to read team member profiles, but restricts modifications to the profile owner.
     * @path /team_members/{teamMemberId}
     * @allow get, list: if true;
     * @allow create: if request.auth.uid == teamMemberId;
     * @allow update: if isExistingOwner(teamMemberId);
     * @allow delete: if isExistingOwner(teamMemberId);
     * @deny create: if request.auth.uid != teamMemberId;
     * @deny update: if !isExistingOwner(teamMemberId);
     * @deny delete: if !isExistingOwner(teamMemberId);
     * @principle Enforces document ownership for writes.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create: if request.auth.uid == teamMemberId;
      allow update: if isExistingOwner(teamMemberId);
      allow delete: if isExistingOwner(teamMemberId);
    }

    /**
     * @description Allows anyone to read stock item details, but restricts writes to authenticated users.
     * @path /stock_items/{stockItemId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Authenticated users can manage stock items.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;

      /**
       * @description Allows anyone to read stock movements, but restricts creation to authenticated users.
       * @path /stock_items/{stockItemId}/movements/{movementId}
       * @allow get, list: if true;
       * @allow create: if isSignedIn();
       * @allow update, delete: if false;
       * @principle Authenticated users can create stock movements.
       */
      match /movements/{movementId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}