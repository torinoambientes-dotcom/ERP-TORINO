/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a user-ownership model for team members,
 *  and allows public read access to projects and stock items. Write access to
 *  projects and stock items is restricted. Stock movements are limited to authenticated users.
 * @data_structure
 *  - /projects/{projectId}: Stores project data.
 *  - /team_members/{teamMemberId}: Stores team member data.
 *  - /stock_items/{stockItemId}: Stores inventory items.
 *  - /stock_items/{stockItemId}/movements/{movementId}: Stores stock movement history.
 * @key_security_decisions
 *  - Team members can only manage their own profiles.
 *  - Public read access for projects and stock items.
 *  - Authenticated users can create stock movements.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read project data, but restricts writes.
     * @path /projects/{projectId}
     * @allow (get, list): Any user can read project data.
     * @deny (create, update, delete): No one can create, update, or delete project data without authentication.
     * @principle Public read, restricted write access.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows team members to manage their own profiles.
     * @path /team_members/{teamMemberId}
     * @allow (get, list): Team members can read their own profile data.
     * @allow (create, update, delete): Team members can create, update, and delete their own profile data.
     * @deny (get, list): Other users cannot access team member profiles.
     * @deny (create, update, delete): Other users cannot modify team member profiles.
     * @principle Enforces document ownership for writes.
     */
    match /team_members/{teamMemberId} {
      allow get: if isOwner(teamMemberId);
      allow list: if false;
      allow create: if isOwner(teamMemberId);
      allow update: if isExistingOwner(teamMemberId);
      allow delete: if isExistingOwner(teamMemberId);
    }

    /**
     * @description Allows anyone to read stock items, but restricts writes.
     * @path /stock_items/{stockItemId}
     * @allow (get, list): Any user can read stock item data.
     * @deny (create, update, delete): No one can create, update, or delete stock item data without authentication.
     * @principle Public read, restricted write access.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Allows authenticated users to create stock movements.
       * @path /stock_items/{stockItemId}/movements/{movementId}
       * @allow (create): Authenticated users can create stock movements.
       * @deny (get, list, update, delete): Read, list, update, and delete operations are not allowed.
       * @principle Authenticated users can create stock movements.
       */
      match /movements/{movementId} {
        allow get, list, update, delete: if false;
        allow create: if isSignedIn();
      }
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}