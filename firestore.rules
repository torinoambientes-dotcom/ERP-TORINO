/**
 * @fileoverview Firestore Security Rules for the furniture management application.
 *
 * Core Philosophy:
 * This ruleset prioritizes ease of access and future modification, granting broad permissions to all authenticated users. While not strictly enforcing data shapes, it ensures that only authenticated users can read and write data.
 *
 * Data Structure:
 * The Firestore database is structured with top-level collections for projects, team members, stock items, stock movements, and stock categories. Projects contain environment and furniture data.
 *
 * Key Security Decisions:
 * - All authenticated users can read and write all data.
 * - No restrictions are placed on data shapes, allowing for flexible development.
 *
 * Note:
 * These rules are designed for rapid prototyping and should be refined in a production environment to include more granular access controls and data validation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read and write project data.
     * @path /projects/{projectId}
     * @allow (read, write) - Any authenticated user can access project data.
     * @deny (none) - No requests are explicitly denied.
     * @principle Allows access to all authenticated users for ease of use and future modifications.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write team member data.
     * @path /team_members/{teamMemberId}
     * @allow (read, write) - Any authenticated user can access team member data.
     * @deny (none) - No requests are explicitly denied.
     * @principle Allows access to all authenticated users for ease of use and future modifications.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (read, write) - Any authenticated user can access stock item data.
     * @deny (none) - No requests are explicitly denied.
     * @principle Allows access to all authenticated users for ease of use and future modifications.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      /**
       * @description Allows any authenticated user to read and write stock movement data.
       * @path /stock_items/{stockItemId}/movements/{movementId}
       * @allow (read, write) - Any authenticated user can access stock movement data.
       * @deny (none) - No requests are explicitly denied.
       * @principle Allows access to all authenticated users for ease of use and future modifications.
       */
      match /movements/{movementId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Allows any authenticated user to read and write stock category data.
     * @path /stock_categories/{stockCategoryId}
     * @allow (read, write) - Any authenticated user can access stock category data.
     * @deny (none) - No requests are explicitly denied.
     * @principle Allows access to all authenticated users for ease of use and future modifications.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }

  // Helper function to determine if a user is signed in
  function isSignedIn() {
    return request.auth != null;
  }
}