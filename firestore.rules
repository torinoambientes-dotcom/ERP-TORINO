/**
 * @fileoverview Firestore Security Rules for the furniture production tracking application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model for projects and team members. Only authenticated users can access data.
 * Projects are the top-level entities, and team members have individual profiles.
 *
 * Data Structure:
 * - /projects/{projectId}: Stores project data.
 * - /team_members/{teamMemberId}: Stores team member data.
 *
 * Key Security Decisions:
 * - All read and write access requires authentication.
 * - Team members can only read and write their own profile.
 * - Anyone can read project data, but only authenticated users can modify it.
 *
 * Denormalization for Authorization:
 * - Project documents do not contain explicit member lists or roles. Therefore, this ruleset defaults to allowing any authenticated user
 *   to read and modify projects. In a production environment, consider denormalizing access control data (e.g., `members: { 'user_abc': 'editor' }`)
 *   onto the project documents themselves to enable more granular, role-based access.
 *   Without denormalization, it's impossible to enforce meaningful authorization on project writes.
 *
 * Structural Segregation:
 * - There is no distinction between private and public data; all collections are treated as requiring authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows reading and writing of project data.
     * @path /projects/{projectId}
     * @allow (get, list): Any authenticated user can read project data.
     * @allow (create, update, delete): Any authenticated user can modify project data.
     * @deny (create, update, delete): Not an authenticated user.
     * @principle Authentication required for writes.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows team members to read and write their own profile data.
     * @path /team_members/{teamMemberId}
     * @allow (get, list): Any authenticated user can read their own profile data.
     * @allow (create, update, delete): Any authenticated user can modify their own profile data.
     * @deny (get, list): Not an authenticated user or trying to access another user's profile.
     * @deny (create, update, delete): Not an authenticated user or trying to modify another user's profile.
     * @principle Enforces document ownership for team member profiles.
     */
    match /team_members/{teamMemberId} {
      allow get: if isSignedIn() && isOwner(teamMemberId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(teamMemberId);
      allow update: if isSignedIn() && isOwner(teamMemberId) && resource != null;
      allow delete: if isSignedIn() && isExistingOwner(teamMemberId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}