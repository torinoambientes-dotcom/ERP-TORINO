/**
 * @file Firestore Security Rules
 * @core-philosophy This ruleset adopts a permissive data shape but enforces strict access control based on ownership.
 *   It prioritizes preventing unauthorized data access over rigorous data validation to enable rapid prototyping.
 * @data-structure
 *   - /projects/{projectId}: Stores project data. Access is unrestricted.
 *   - /team_members/{teamMemberId}: Stores team member information. Access is unrestricted.
 *   - /stock_items/{stockItemId}: Stores inventory items. Access is unrestricted.
 *   - /stock_items/{stockItemId}/movements/{movementId}: Stores movement history for stock items. Access is unrestricted.
 *   - /stock_categories/{stockCategoryId}: Stores stock item categories. Access is unrestricted.
 * @key-security-decisions
 *   - Unrestricted access to all collections. This should be changed after the prototyping phase.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read and write project data.
     * @path /projects/{projectId}
     * @allow (get, list, create, update, delete) Any authenticated user can perform any operation.
     * @deny None. All requests are allowed.
     * @principle No access control is enforced.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read and write team member data.
     * @path /team_members/{teamMemberId}
     * @allow (get, list, create, update, delete) Any authenticated user can perform any operation.
     * @deny None. All requests are allowed.
     * @principle No access control is enforced.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read and write stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (get, list, create, update, delete) Any authenticated user can perform any operation.
     * @deny None. All requests are allowed.
     * @principle No access control is enforced.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read and write stock movement data.
     * @path /stock_items/{stockItemId}/movements/{movementId}
     * @allow (get, list, create, update, delete) Any authenticated user can perform any operation.
     * @deny None. All requests are allowed.
     * @principle No access control is enforced.
     */
    match /stock_items/{stockItemId}/movements/{movementId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read and write stock category data.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list, create, update, delete) Any authenticated user can perform any operation.
     * @deny None. All requests are allowed.
     * @principle No access control is enforced.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}