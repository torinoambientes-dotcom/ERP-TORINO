/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset is configured to remove all security restrictions, as requested by the user.
 * This configuration is strongly discouraged for production environments due to the risk of
 * unauthorized data access and modification.
 *
 * Data Structure:
 * The Firestore database is structured with top-level collections for projects, team members,
 * and stock items. Stock items have a subcollection for tracking movements.
 *
 * Key Security Decisions:
 * ALL restrictions are removed, providing open read and write access to all data.
 * This is NOT a recommended configuration for production use.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read or write project data.
     * @path /projects/{projectId}
     * @allow (create, update, delete, get, list) - Any user can perform any operation.
     * @deny None.
     * @principle All security is disabled.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read or write team member data.
     * @path /team_members/{teamMemberId}
     * @allow (create, update, delete, get, list) - Any user can perform any operation.
     * @deny None.
     * @principle All security is disabled.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read or write stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (create, update, delete, get, list) - Any user can perform any operation.
     * @deny None.
     * @principle All security is disabled.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read or write stock movement data.
     * @path /stock_items/{stockItemId}/movements/{movementId}
     * @allow (create, update, delete, get, list) - Any user can perform any operation.
     * @deny None.
     * @principle All security is disabled.
     */
    match /stock_items/{stockItemId}/movements/{movementId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}