/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for most collections,
 * ensuring that only authenticated users can create, read, update, or delete
 * documents they own. Collections such as `projects`, `team_members`, `appointments`, `stock_items`, `stock_movements`, `stock_categories`, `purchase_requests`, `quotes`, `quote_materials`, and `quote_material_categories` are secured in this way.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for projects, team members,
 * appointments, stock items, stock movements, stock categories, purchase requests, quotes, quote materials, and quote material categories.
 * There are no user-scoped subcollections in this data model.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed to prevent unauthorized access to user data.
 * - Read-only collections are not explicitly defined, but could be implemented by setting
 *   `allow get, list: if true;` and denying all write operations.
 * - Ambiguous relationships default to a strict owner-only access model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to projects, enforcing ownership for writes.
     * @path /projects/{projectId}
     * @allow (create) - Authenticated user can create a project.
     * @allow (get, list) - Anyone can read project data.
     * @allow (update, delete) - Only the project owner can modify or delete a project.
     * @deny (create) - Non-authenticated user cannot create a project.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this project.
     * @principle Enforces document ownership for writes.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to team members, enforcing ownership for writes.
     * @path /team_members/{teamMemberId}
     * @allow (create) - Authenticated user can create a team member.
     * @allow (get, list) - Anyone can read team member data.
     * @allow (update, delete) - Only the team member owner can modify or delete a team member.
     * @deny (create) - Non-authenticated user cannot create a team member.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this team member.
     * @principle Enforces document ownership for writes.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to appointments, enforcing ownership for writes.
     * @path /appointments/{appointmentId}
     * @allow (create) - Authenticated user can create a appointment.
     * @allow (get, list) - Anyone can read appointment data.
     * @allow (update, delete) - Only the appointment owner can modify or delete a appointment.
     * @deny (create) - Non-authenticated user cannot create a appointment.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this appointment.
     * @principle Enforces document ownership for writes.
     */
    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to stock items, enforcing ownership for writes.
     * @path /stock_items/{stockItemId}
     * @allow (create) - Authenticated user can create a stock item.
     * @allow (get, list) - Anyone can read stock item data.
     * @allow (update, delete) - Only the stock item owner can modify or delete a stock item.
     * @deny (create) - Non-authenticated user cannot create a stock item.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this stock item.
     * @principle Enforces document ownership for writes.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to stock movements, enforcing ownership for writes.
     * @path /stock_movements/{movementId}
     * @allow (create) - Authenticated user can create a stock movement.
     * @allow (get, list) - Anyone can read stock movement data.
     * @allow (update, delete) - Only the stock movement owner can modify or delete a stock movement.
     * @deny (create) - Non-authenticated user cannot create a stock movement.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this stock movement.
     * @principle Enforces document ownership for writes.
     */
    match /stock_movements/{movementId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to stock categories, enforcing ownership for writes.
     * @path /stock_categories/{stockCategoryId}
     * @allow (create) - Authenticated user can create a stock category.
     * @allow (get, list) - Anyone can read stock category data.
     * @allow (update, delete) - Only the stock category owner can modify or delete a stock category.
     * @deny (create) - Non-authenticated user cannot create a stock category.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this stock category.
     * @principle Enforces document ownership for writes.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to purchase requests, enforcing ownership for writes.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (create) - Authenticated user can create a purchase request.
     * @allow (get, list) - Anyone can read purchase request data.
     * @allow (update, delete) - Only the purchase request owner can modify or delete a purchase request.
     * @deny (create) - Non-authenticated user cannot create a purchase request.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this purchase request.
     * @principle Enforces document ownership for writes.
     */
    match /purchase_requests/{purchaseRequestId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to quotes, enforcing ownership for writes.
     * @path /quotes/{quoteId}
     * @allow (create) - Authenticated user can create a quote.
     * @allow (get, list) - Anyone can read quote data.
     * @allow (update, delete) - Only the quote owner can modify or delete a quote.
     * @deny (create) - Non-authenticated user cannot create a quote.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this quote.
     * @principle Enforces document ownership for writes.
     */
    match /quotes/{quoteId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to quote materials, enforcing ownership for writes.
     * @path /quote_materials/{quoteMaterialId}
     * @allow (create) - Authenticated user can create a quote material.
     * @allow (get, list) - Anyone can read quote material data.
     * @allow (update, delete) - Only the quote material owner can modify or delete a quote material.
     * @deny (create) - Non-authenticated user cannot create a quote material.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this quote material.
     * @principle Enforces document ownership for writes.
     */
    match /quote_materials/{quoteMaterialId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants access to quote material categories, enforcing ownership for writes.
     * @path /quote_material_categories/{quoteMaterialCategoryId}
     * @allow (create) - Authenticated user can create a quote material category.
     * @allow (get, list) - Anyone can read quote material category data.
     * @allow (update, delete) - Only the quote material category owner can modify or delete a quote material category.
     * @deny (create) - Non-authenticated user cannot create a quote material category.
     * @deny (update, delete) - A different authenticated user cannot modify or delete this quote material category.
     * @principle Enforces document ownership for writes.
     */
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}