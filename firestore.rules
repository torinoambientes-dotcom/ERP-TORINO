rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated (user is signed in).
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId The user ID to compare against.
     * @return {boolean} True if the user ID matches the authenticated user's ID, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     * @param {string} userId The user ID to compare against.
     * @return {boolean} True if the user ID matches the authenticated user's ID and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces owner-only access for the 'projects' collection.
     * @path /projects/{projectId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a project with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a project with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a project.
     * @deny (get) An unauthenticated user cannot get a project.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a project with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a project with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a project with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a project with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'team_members' collection.
     * @path /team_members/{teamMemberId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a team_member with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a team_member with id 'someOtherId'.
     * @allow (get) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can get their own team_member document.
     * @deny (get) User 'someOtherId' cannot get team_member document.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update their own team_member document.
     * @deny (update) User 'someOtherId' cannot update team_member document.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete their own team_member document.
     * @deny (delete) User 'someOtherId' cannot delete team_member document.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /team_members/{teamMemberId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'appointments' collection.
     * @path /appointments/{appointmentId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a appointment with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a appointment with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a appointment.
     * @deny (get) An unauthenticated user cannot get a appointment.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a appointment with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a appointment with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a appointment with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a appointment with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /appointments/{appointmentId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'stock_items' collection.
     * @path /stock_items/{stockItemId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a stock_item with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a stock_item with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a stock_item.
     * @deny (get) An unauthenticated user cannot get a stock_item.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a stock_item with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a stock_item with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a stock_item with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a stock_item with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /stock_items/{stockItemId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'stock_movements' collection.
     * @path /stock_movements/{movementId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a stock_movement with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a stock_movement with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a stock_movement.
     * @deny (get) An unauthenticated user cannot get a stock_movement.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a stock_movement with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a stock_movement with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a stock_movement with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a stock_movement with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /stock_movements/{movementId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'stock_categories' collection.
     * @path /stock_categories/{stockCategoryId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a stock_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a stock_category with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a stock_category.
     * @deny (get) An unauthenticated user cannot get a stock_category.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a stock_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a stock_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a stock_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a stock_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /stock_categories/{stockCategoryId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'purchase_requests' collection.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a purchase_request with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a purchase_request with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a purchase_request.
     * @deny (get) An unauthenticated user cannot get a purchase_request.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a purchase_request with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a purchase_request with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a purchase_request with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a purchase_request with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /purchase_requests/{purchaseRequestId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'quotes' collection.
     * @path /quotes/{quoteId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a quote with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a quote with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a quote.
     * @deny (get) An unauthenticated user cannot get a quote.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a quote with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a quote with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a quote with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a quote with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /quotes/{quoteId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'quote_materials' collection.
     * @path /quote_materials/{quoteMaterialId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a quote_material with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a quote_material with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a quote_material.
     * @deny (get) An unauthenticated user cannot get a quote_material.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a quote_material with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a quote_material with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a quote_material with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a quote_material with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /quote_materials/{quoteMaterialId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }

    /**
     * @description Enforces owner-only access for the 'quote_material_categories' collection.
     * @path /quote_material_categories/{quoteMaterialCategoryId}
     * @allow (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can create a quote_material_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (create) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' cannot create a quote_material_category with id 'someOtherId'.
     * @allow (get) Any signed-in user can get a quote_material_category.
     * @deny (get) An unauthenticated user cannot get a quote_material_category.
     * @allow (update) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can update a quote_material_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (update) User 'someOtherId' cannot update a quote_material_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @allow (delete) User 'aBJAeH6jjoNrPySlMlwKeUpBOCV2' can delete a quote_material_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @deny (delete) User 'someOtherId' cannot delete a quote_material_category with id 'aBJAeH6jjoNrPySlMlwKeUpBOCV2'.
     * @principle Enforces document ownership for writes. Allows public reads.
     */
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.owner_uid && request.auth.uid == resource.data.owner_uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.owner_uid;
    }
  }
}