/**
 * @fileoverview Firestore Security Rules for internal application use.
 *
 * Core Philosophy:
 * This ruleset is configured for an internal application with no specific security concerns.
 * All read and write operations are permitted for all users.
 *
 * Data Structure:
 * The database contains projects and team members, with no specific hierarchical structure.
 *
 * Key Security Decisions:
 * All authenticated users have full read and write access to all data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read and write project data.
     * @path /projects/{projectId}
     * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
     * @deny (none) - No operation is denied for authenticated users.
     * @principle No security restrictions for internal app use.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows any authenticated user to read and write team member data.
     * @path /team_members/{teamMemberId}
     * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
     * @deny (none) - No operation is denied for authenticated users.
     * @principle No security restrictions for internal app use.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}