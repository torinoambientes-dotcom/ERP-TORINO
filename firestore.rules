
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for factory display and general access
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /team_members/{memberId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /appointments/{appointmentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Cutting Orders - Public read and status update for factory monitors
    match /cutting_orders/{cuttingOrderId} {
      allow read: if true;
      allow write: if true;
    }

    // Authenticated access only
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    match /stock_items/{stockItemId} {
      allow read, write: if request.auth != null;
    }
    match /stock_categories/{stockCategoryId} {
      allow read, write: if request.auth != null;
    }
    match /stock_movements/{movementId} {
      allow read, write: if request.auth != null;
    }
    match /purchase_requests/{purchaseRequestId} {
      allow read, write: if request.auth != null;
    }
    match /quotes/{quoteId} {
      allow read, write: if request.auth != null;
    }
    match /quote_materials/{quoteMaterialId} {
      allow read, write: if request.auth != null;
    }
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow read, write: if request.auth != null;
    }
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    match /suppliers/{supplierId} {
      allow read, write: if request.auth != null;
    }
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }
  }
}
