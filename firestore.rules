/**
 * @file Firestore Security Rules
 * @description This ruleset allows completely open access to all data.
 *
 * Core Philosophy:
 * This ruleset is generated in prototyping mode, allowing any operation from any user, including unauthenticated users.
 * This is NOT recommended for production use.
 *
 * Data Structure:
 * The database contains projects and team members stored in top-level collections.
 * /projects/{projectId} : Stores all project data.
 * /team_members/{teamMemberId} : Stores information about team members.
 *
 * Key Security Decisions:
 * All read and write operations are allowed. This should only be used for initial development and testing.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows completely open access to project data.
     * @path /projects/{projectId}
     * @allow (read, write) Any user can read or write any project.
     * @deny (none) No requests are denied.
     * @principle Open access for prototyping.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Allows completely open access to team member data.
     * @path /team_members/{teamMemberId}
     * @allow (read, write) Any user can read or write any team member.
     * @deny (none) No requests are denied.
     * @principle Open access for prototyping.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}