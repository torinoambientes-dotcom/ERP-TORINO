/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset provides completely open read and write access to all collections. This configuration is intended for rapid prototyping and disables all authorization checks.
 *
 * Data Structure:
 * The database contains several top-level collections, including 'projects', 'team_members', 'appointments', 'stock_items', 'stock_movements', 'stock_categories', 'purchase_requests', 'quotes', 'quote_materials', and 'quote_material_categories'. Each collection stores documents of a specific entity type.
 *
 * Key Security Decisions:
 * - All read and write access is granted to any authenticated user. This disables all security checks.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants open access to all projects.
     * @path /projects/{projectId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete projects.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all team members.
     * @path /team_members/{teamMemberId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete team members.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all appointments.
     * @path /appointments/{appointmentId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete appointments.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all stock items.
     * @path /stock_items/{stockItemId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete stock items.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all stock movements.
     * @path /stock_movements/{movementId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete stock movements.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /stock_movements/{movementId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all stock categories.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete stock categories.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all purchase requests.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete purchase requests.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /purchase_requests/{purchaseRequestId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all quotes.
     * @path /quotes/{quoteId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete quotes.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /quotes/{quoteId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all quote materials.
     * @path /quote_materials/{quoteMaterialId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete quote materials.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /quote_materials/{quoteMaterialId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Grants open access to all quote material categories.
     * @path /quote_material_categories/{quoteMaterialCategoryId}
     * @allow (get, list, create, update, delete) - Any authenticated user can read, create, update, and delete quote material categories.
     * @deny None
     * @principle Disables all authorization checks.
     */
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}