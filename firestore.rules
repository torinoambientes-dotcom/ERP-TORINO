/**
 * @file Firestore Security Rules
 * @description This ruleset configures completely open access to all data for authenticated users.
 *
 * Core Philosophy:
 * The ruleset is designed to grant any logged-in user full access to all data, meaning any authenticated user can read, write, create, update, and delete any document in any collection.
 *
 * Data Structure:
 * The Firestore database contains several top-level collections, including `projects`, `team_members`, `appointments`, `stock_items`, `stock_movements`, `stock_categories`, `purchase_requests`, `quotes`, `quote_materials`, and `quote_material_categories`.
 *
 * Key Security Decisions:
 * - All authenticated users can read any data.
 * - All authenticated users can create, update, and delete any data.
 * - There are no restrictions based on roles, ownership, or any other criteria.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read, create, update, and delete project data.
     * @path /projects/{projectId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to project data for any authenticated user.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete team member data.
     * @path /team_members/{teamMemberId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to team member data for any authenticated user.
     */
    match /team_members/{teamMemberId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete appointment data.
     * @path /appointments/{appointmentId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to appointment data for any authenticated user.
     */
    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete stock item data.
     * @path /stock_items/{stockItemId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to stock item data for any authenticated user.
     */
    match /stock_items/{stockItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete stock movement data.
     * @path /stock_movements/{movementId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to stock movement data for any authenticated user.
     */
    match /stock_movements/{movementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete stock category data.
     * @path /stock_categories/{stockCategoryId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to stock category data for any authenticated user.
     */
    match /stock_categories/{stockCategoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete purchase request data.
     * @path /purchase_requests/{purchaseRequestId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to purchase request data for any authenticated user.
     */
    match /purchase_requests/{purchaseRequestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete quote data.
     * @path /quotes/{quoteId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to quote data for any authenticated user.
     */
    match /quotes/{quoteId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete quote material data.
     * @path /quote_materials/{quoteMaterialId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to quote material data for any authenticated user.
     */
    match /quote_materials/{quoteMaterialId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read, create, update, and delete quote material category data.
     * @path /quote_material_categories/{quoteMaterialCategoryId}
     * @allow (get, list) User is authenticated.
     * @allow (create, update, delete) User is authenticated.
     * @deny (create, update, delete) User is not authenticated.
     * @principle Grants full access to quote material category data for any authenticated user.
     */
    match /quote_material_categories/{quoteMaterialCategoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}